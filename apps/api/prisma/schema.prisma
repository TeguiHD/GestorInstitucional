// =============================================================================
// Asistencia — Prisma Schema
// MariaDB (mysql provider) · multi-school · RBAC · audit
// =============================================================================

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// ENUMS
// =============================================================================

enum UserStatus {
  ACTIVE
  INACTIVE
  LOCKED
}

enum SystemRole {
  SUPER_ADMIN
  DIRECTOR
  UTP
  PROFESOR
  APODERADO
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  JUSTIFIED
  WITHDRAWN
}

enum CalendarDayType {
  HOLIDAY
  SUSPENDED
  EVENT
}

enum JustificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum MailStatus {
  PENDING
  SENDING
  SENT
  FAILED
  CANCELLED
}

enum MailPriority {
  HIGH
  NORMAL
  LOW
}

enum MailCategory {
  ABSENCE_DAILY
  JUSTIFICATION_RESULT
  WEEKLY_DIGEST
  CLASS_SUSPENSION
  BROADCAST
  SYSTEM
}

enum AlertTrigger {
  STUDENT_BELOW_THRESHOLD     // student attendance < threshold
  COURSE_BELOW_THRESHOLD      // course avg < threshold
  STUDENT_CONSECUTIVE_ABSENCES // N consecutive absences
  TEACHER_NO_RECORD           // teacher hasn't recorded attendance in N days
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  LOGIN_FAILED
  PASSWORD_CHANGE
  TOTP_ENABLE
  TOTP_DISABLE
  TOKEN_REVOKE
  EXPORT
  PERMISSION_CHANGE
}

enum GradePeriod {
  P1
  P2
  E1
  P3
  P4
  E2
  NF
}

enum EnrollmentStatus {
  ACTIVE
  WITHDRAWN
  TRANSFERRED_OUT
  TRANSFERRED_IN
  RE_ENROLLED
  GRADUATED
}

// =============================================================================
// SCHOOL (multi-tenant root)
// =============================================================================

model School {
  id        String   @id @default(uuid()) @db.Char(36)
  name      String   @db.VarChar(200)
  slug      String   @unique @db.VarChar(80)
  address   String?  @db.VarChar(300)
  phone     String?  @db.VarChar(30)
  logoUrl   String?  @db.VarChar(500)
  rbd       String?  @db.VarChar(10)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users        UserSchoolRole[]
  courses      Course[]
  students     Student[]
  permissions  SchoolPermission[]
  calendarDays SchoolCalendarDay[]
  alertRules   AlertRule[]
  subjects     Subject[]

  @@map("schools")
}

// =============================================================================
// USERS
// =============================================================================

model User {
  id           String     @id @default(uuid()) @db.Char(36)
  email        String     @unique @db.VarChar(255)
  passwordHash String     @db.VarChar(500)
  firstName    String     @db.VarChar(80)
  lastName     String     @db.VarChar(80)
  phone        String?    @db.VarChar(30)
  status       UserStatus @default(ACTIVE)
  failedLogins Int        @default(0)
  lockedUntil  DateTime?
  lastLoginAt  DateTime?
  lastLoginIp  String?    @db.VarChar(45)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  deletedAt    DateTime?

  schoolRoles    UserSchoolRole[]
  totpSecrets    TotpSecret[]
  refreshTokens  RefreshToken[]
  courseTeacher  CourseTeacher[]
  guardianships  Guardianship[]
  attendanceLogs        AttendanceRecord[]        @relation("RecordedBy")
  justificationsUploaded AttendanceJustification[] @relation("JustifUploader")
  justificationsReviewed AttendanceJustification[] @relation("JustifReviewer")
  auditEvents           AuditEvent[]
  trustedDevices        TrustedDevice[]
  notifications         Notification[]
  guardianContacts      GuardianContact[]
  gradesRecorded        Grade[]           @relation("GradeRecordedBy")
  subjectsTeaching      Subject[]         @relation("SubjectTeacher")
  scheduleSlots         ScheduleSlot[]    @relation("SlotTeacher")
  enrollmentEvents      EnrollmentEvent[] @relation("EnrollmentRecordedBy")

  @@index([email])
  @@index([deletedAt])
  @@map("users")
}

model UserSchoolRole {
  id       String     @id @default(uuid()) @db.Char(36)
  userId   String     @db.Char(36)
  schoolId String     @db.Char(36)
  role     SystemRole

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([userId, schoolId, role])
  @@index([userId])
  @@index([schoolId])
  @@map("user_school_roles")
}

// Granular permissions (extend RBAC beyond roles when needed)
model SchoolPermission {
  id         String   @id @default(uuid()) @db.Char(36)
  schoolId   String   @db.Char(36)
  role       SystemRole
  permission String   @db.VarChar(100) // e.g. "attendance:write", "reports:export"
  createdAt  DateTime @default(now())

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([schoolId, role, permission])
  @@map("school_permissions")
}

// =============================================================================
// AUTH
// =============================================================================

model TotpSecret {
  id         String    @id @default(uuid()) @db.Char(36)
  userId     String    @db.Char(36)
  secret     String    @db.VarChar(300) // encrypted at rest
  verified   Boolean   @default(false)
  backupCodes Json                       // hashed backup codes
  createdAt  DateTime  @default(now())
  verifiedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId])
  @@map("totp_secrets")
}

model RefreshToken {
  id         String    @id @default(uuid()) @db.Char(36)
  userId     String    @db.Char(36)
  tokenHash  String    @db.Char(64) // SHA-256 of raw token
  family     String    @db.Char(36) // UUID grouping token lineage (reuse → revoke family)
  ip         String?   @db.VarChar(45)
  userAgent  String?   @db.VarChar(400)
  expiresAt  DateTime
  revokedAt  DateTime?
  usedAt     DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tokenHash])
  @@index([userId])
  @@index([family])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model TrustedDevice {
  id         String   @id @default(uuid()) @db.Char(36)
  userId     String   @db.Char(36)
  tokenHash  String   @db.Char(64)          // SHA-256 hex of raw token
  userAgent  String?  @db.VarChar(500)
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@map("trusted_devices")
}

model Notification {
  id        String    @id @default(uuid()) @db.Char(36)
  userId    String    @db.Char(36)
  type      String    @db.VarChar(40)
  title     String    @db.VarChar(200)
  body      String    @db.VarChar(500)
  link      String?   @db.VarChar(500)
  readAt    DateTime?
  createdAt DateTime  @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@index([userId, createdAt])
  @@map("notifications")
}

// =============================================================================
// COURSES
// =============================================================================

model Course {
  id            String   @id @default(uuid()) @db.Char(36)
  schoolId      String   @db.Char(36)
  code          String   @db.VarChar(10)   // "1A", "2B"
  name          String   @db.VarChar(120)  // "1° Básico A"
  level         String   @db.VarChar(40)   // "Básica", "Media"
  year          Int
  headTeacherId String?  @db.Char(36)
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  school         School             @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  teachers       CourseTeacher[]
  students       Student[]
  attendance     AttendanceRecord[]
  subjects       Subject[]
  scheduleSlots  ScheduleSlot[]

  @@unique([schoolId, code, year])
  @@index([schoolId])
  @@index([year])
  @@map("courses")
}

model CourseTeacher {
  id        String   @id @default(uuid()) @db.Char(36)
  courseId  String   @db.Char(36)
  userId    String   @db.Char(36)
  isHead    Boolean  @default(false)
  createdAt DateTime @default(now())

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([courseId, userId])
  @@index([userId])
  @@map("course_teachers")
}

// =============================================================================
// STUDENTS
// =============================================================================

model Student {
  id               String    @id @default(uuid()) @db.Char(36)
  schoolId         String    @db.Char(36)
  courseId         String    @db.Char(36)
  rut              String    @db.VarChar(12) // without dots: "12345678-9"
  firstName        String    @db.VarChar(80)
  lastName         String    @db.VarChar(80)
  secondLastName   String?   @db.VarChar(80)
  birthDate        DateTime? @db.Date
  enrollmentNumber Int
  active           Boolean   @default(true)
  withdrawnAt      DateTime?
  enrolledAt       DateTime  @default(now())
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  school        School             @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  course        Course             @relation(fields: [courseId], references: [id])
  guardianships     Guardianship[]
  attendance        AttendanceRecord[]
  grades            Grade[]
  enrollmentHistory EnrollmentEvent[]

  @@unique([schoolId, rut])
  @@unique([courseId, enrollmentNumber])
  @@index([courseId])
  @@index([schoolId])
  @@map("students")
}

model Guardianship {
  id          String   @id @default(uuid()) @db.Char(36)
  guardianId  String   @db.Char(36) // userId with role APODERADO
  studentId   String   @db.Char(36)
  relation    String   @db.VarChar(40) // "Padre", "Madre", "Tutor"
  isPrimary   Boolean  @default(false)
  notifyAbsences     Boolean  @default(true)
  notifyLate         Boolean  @default(true)
  notifyWeeklyDigest Boolean  @default(false)
  notifyUntil DateTime?
  createdAt   DateTime @default(now())

  guardian User    @relation(fields: [guardianId], references: [id], onDelete: Cascade)
  student  Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([guardianId, studentId])
  @@index([studentId])
  @@map("guardianships")
}

model GuardianContact {
  id          String   @id @default(uuid()) @db.Char(36)
  userId      String   @db.Char(36)
  type        String   @db.VarChar(20)
  phone       String   @db.VarChar(30)
  label       String?  @db.VarChar(80)
  isWhatsApp  Boolean  @default(false)
  priority    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("guardian_contacts")
}

// =============================================================================
// ATTENDANCE
// =============================================================================

model AttendanceRecord {
  id           String           @id @default(uuid()) @db.Char(36)
  studentId    String           @db.Char(36)
  courseId     String           @db.Char(36)
  date         DateTime         @db.Date
  status       AttendanceStatus
  note         String?          @db.VarChar(500)
  lateMinutes  Int?             // when LATE, optional minutes
  recordedById String           @db.Char(36)
  recordedAt   DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  student        Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  course         Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  recordedBy     User    @relation("RecordedBy", fields: [recordedById], references: [id])
  justifications AttendanceJustification[]

  @@unique([studentId, date])
  @@index([courseId, date])
  @@index([studentId])
  @@index([date])
  @@map("attendance_records")
}

model AttendanceJustification {
  id             String              @id @default(uuid()) @db.Char(36)
  recordId       String              @db.Char(36)
  uploadedById   String              @db.Char(36)
  fileName       String              @db.VarChar(255)
  filePath       String              @db.VarChar(500)
  mimeType       String              @db.VarChar(120)
  sizeBytes      Int
  fileHash       String?             @db.VarChar(64)
  reason         String              @db.VarChar(500)
  status         JustificationStatus @default(PENDING)
  reviewedById   String?             @db.Char(36)
  reviewedAt     DateTime?
  reviewNotes    String?             @db.VarChar(500)
  createdAt      DateTime            @default(now())

  record     AttendanceRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)
  uploadedBy User             @relation("JustifUploader", fields: [uploadedById], references: [id])
  reviewedBy User?            @relation("JustifReviewer", fields: [reviewedById], references: [id])

  @@index([recordId])
  @@index([status])
  @@index([uploadedById, createdAt])
  @@map("attendance_justifications")
}

// =============================================================================
// CALENDAR (holidays, suspended days, events)
// =============================================================================

model SchoolCalendarDay {
  id          String          @id @default(uuid()) @db.Char(36)
  schoolId    String          @db.Char(36)
  date        DateTime        @db.Date
  type        CalendarDayType
  description String          @db.VarChar(200)
  createdAt   DateTime        @default(now())

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([schoolId, date])
  @@index([schoolId, date])
  @@map("school_calendar_days")
}

// =============================================================================
// MAIL OUTBOX (queued email with daily quota — Brevo HTTPS API)
// =============================================================================

model MailOutbox {
  id            String       @id @default(uuid()) @db.Char(36)
  schoolId      String?      @db.Char(36)
  toEmail       String       @db.VarChar(255)
  toName        String?      @db.VarChar(200)
  subject       String       @db.VarChar(300)
  htmlBody      String       @db.MediumText
  textBody      String?      @db.Text
  category      MailCategory
  priority      MailPriority @default(NORMAL)
  status        MailStatus   @default(PENDING)
  dedupeKey     String?      @db.VarChar(160) // prevents duplicate enqueue (e.g. absence+recordId)
  attempts      Int          @default(0)
  lastError     String?      @db.VarChar(500)
  scheduledFor  DateTime?
  sentAt        DateTime?
  providerMsgId String?      @db.VarChar(200)
  relatedType   String?      @db.VarChar(40) // "AttendanceRecord" | "Justification" | "CalendarDay"
  relatedId     String?      @db.VarChar(36)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@unique([dedupeKey])
  @@index([status, priority, scheduledFor])
  @@index([schoolId, category, createdAt])
  @@index([createdAt])
  @@map("mail_outbox")
}

// =============================================================================
// ALERT RULES
// =============================================================================

model AlertRule {
  id          String       @id @default(uuid()) @db.Char(36)
  schoolId    String       @db.Char(36)
  trigger     AlertTrigger
  threshold   Float?       // e.g. 0.85 for 85% attendance
  windowDays  Int          @default(30) // rolling window in days
  enabled     Boolean      @default(true)
  notifyRoles Json         // string[] — roles to notify e.g. ["DIRECTOR","UTP"]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  school      School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  fired       AlertFired[]

  @@unique([schoolId, trigger])
  @@index([schoolId])
  @@map("alert_rules")
}

model AlertFired {
  id          String    @id @default(uuid()) @db.Char(36)
  ruleId      String    @db.Char(36)
  entityType  String    @db.VarChar(30)  // "student" | "course" | "teacher"
  entityId    String    @db.Char(36)
  meta        Json?
  firedAt     DateTime  @default(now())

  rule        AlertRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@index([ruleId])
  @@index([firedAt])
  @@map("alert_fired")
}

// =============================================================================
// AUDIT LOG (append-only — no updates, no deletes via app)
// =============================================================================

model AuditEvent {
  id        String      @id @default(uuid()) @db.Char(36)
  userId    String?     @db.Char(36)
  action    AuditAction
  entity    String?     @db.VarChar(60)  // "User", "Course", "AttendanceRecord"
  entityId  String?     @db.VarChar(36)
  meta      Json?                         // diff or extra context
  ip        String?     @db.VarChar(45)
  userAgent String?     @db.VarChar(400)
  prevHash  String?     @db.Char(64)     // SHA-256 chain for tamper-detection
  hash      String      @db.Char(64)     // SHA-256(id+userId+action+entity+entityId+createdAt+prevHash)
  createdAt DateTime    @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
  @@map("audit_events")
}

// =============================================================================
// SUBJECTS + GRADES
// =============================================================================

model Subject {
  id           String   @id @default(uuid()) @db.Char(36)
  schoolId     String   @db.Char(36)
  courseId     String   @db.Char(36)
  name         String   @db.VarChar(120)
  code         String   @db.VarChar(20)
  teacherId    String?  @db.Char(36)
  semester     Int      @default(0)
  hoursPerWeek Int      @default(4)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  school         School         @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  course         Course         @relation(fields: [courseId], references: [id], onDelete: Cascade)
  teacher        User?          @relation("SubjectTeacher", fields: [teacherId], references: [id], onDelete: SetNull)
  grades         Grade[]
  scheduleSlots  ScheduleSlot[]

  @@unique([courseId, code])
  @@index([courseId])
  @@index([schoolId])
  @@map("subjects")
}

model Grade {
  id           String      @id @default(uuid()) @db.Char(36)
  studentId    String      @db.Char(36)
  subjectId    String      @db.Char(36)
  period       GradePeriod
  value        Decimal     @db.Decimal(4, 1)
  comment      String?     @db.VarChar(200)
  recordedById String      @db.Char(36)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  student      Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subject      Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  recordedBy   User    @relation("GradeRecordedBy", fields: [recordedById], references: [id])

  @@unique([studentId, subjectId, period])
  @@index([subjectId])
  @@index([studentId])
  @@map("grades")
}

// =============================================================================
// HORARIOS
// =============================================================================

model ScheduleSlot {
  id          String   @id @default(uuid()) @db.Char(36)
  courseId    String   @db.Char(36)
  subjectId   String   @db.Char(36)
  teacherId   String   @db.Char(36)
  dayOfWeek   Int      // 1=Lunes, 2=Martes, 3=Miércoles, 4=Jueves, 5=Viernes
  slotNumber  Int      // 1–8 (bloque dentro del día)
  startTime   String   @db.VarChar(5)
  endTime     String   @db.VarChar(5)
  roomNumber  String?  @db.VarChar(20)
  year        Int
  semester    Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  course  Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  teacher User    @relation("SlotTeacher", fields: [teacherId], references: [id])

  @@unique([courseId, dayOfWeek, slotNumber, year, semester])
  @@index([courseId])
  @@index([teacherId])
  @@map("schedule_slots")
}

// =============================================================================
// ENROLLMENT LIFECYCLE
// =============================================================================

model EnrollmentEvent {
  id                    String           @id @default(uuid()) @db.Char(36)
  studentId             String           @db.Char(36)
  courseId              String           @db.Char(36)
  schoolId              String           @db.Char(36)
  status                EnrollmentStatus
  effectiveDate         DateTime         @db.Date
  reason                String?          @db.VarChar(200)
  transferredToCourseId String?          @db.Char(36)
  transferredToSchool   String?          @db.VarChar(200)
  externalGrades        Json?
  recordedById          String           @db.Char(36)
  createdAt             DateTime         @default(now())

  student      Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  recordedBy   User     @relation("EnrollmentRecordedBy", fields: [recordedById], references: [id])

  @@index([studentId])
  @@index([courseId])
  @@index([schoolId])
  @@index([effectiveDate])
  @@map("enrollment_events")
}
